# ==================== 远程服务配置 ====================
# 以下配置项需要根据实际部署环境修改

# 地图服务地址
MAP_TARGET=http://1.14.100.199:8888

# WebSocket服务地址
WS_TARGET=ws://1.14.100.199:8050

# 服务器端口（一般无需修改，沙箱环境自动使用 DEPLOY_RUN_PORT）
PORT=5000

# ==================== 前端构建变量（Vite） ====================
# 注意：VITE_ 前缀变量在构建时注入，构建后需通过 config.js 动态覆盖

VITE_MAP_TARGET=http://1.14.100.199:8888
VITE_WS_TARGET=ws://1.14.100.199:8050
