NODE_ENV=development

# WebSocket配置
WS_PORT=5000
WS_PATH=/ws
WS_MAX_CONNECTIONS=5000
WS_HEARTBEAT_INTERVAL=30000
WS_HEARTBEAT_TIMEOUT=60000

# TCP配置
TCP_RECONNECT_INTERVAL=5000
TCP_HEARTBEAT_INTERVAL=60000

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ky_project
DB_USER=ky_user
DB_PASSWORD=your_password
DB_POOL_MAX=100
DB_POOL_MIN=10

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT配置
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# 日志配置
LOG_LEVEL=info
LOG_FILE_PATH=./logs
